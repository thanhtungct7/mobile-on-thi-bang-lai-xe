<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Luyện tập thôi!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/fg"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/card_stroke"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Cài đặt" />

            </LinearLayout>

        </LinearLayout>

        <!-- Hero readiness card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/accent_card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MỨC ĐỘ SẴN SÀNG"
                android:textSize="11sp"
                android:textColor="#99FFFFFF"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <com.kma.OnThiBangLaiXe.ReadinessRingView
                android:id="@+id/readinessRing"
                android:layout_width="116dp"
                android:layout_height="116dp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/txtReadinessSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#C8FFFFFF"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnStartPractice"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="Luyện tập ngay"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:backgroundTint="@color/white"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Today stats -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TỔNG CỘNG"
            android:textSize="11sp"
            android:textColor="@color/muted"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_stroke"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginHorizontal="4dp">

                <TextView
                    android:id="@+id/txtStatQuestions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/fg"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã làm"
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_stroke"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginHorizontal="4dp">

                <TextView
                    android:id="@+id/txtStatAccuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/fg"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chính xác"
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_stroke"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginHorizontal="4dp">

                <TextView
                    android:id="@+id/txtStatTopics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/5"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/fg"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chủ đề"
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Weak areas -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CẦN ÔN LẠI"
            android:textSize="11sp"
            android:textColor="@color/muted"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/cardWeakAreas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/card_stroke"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWeakAreas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtNoWeakAreas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/card_stroke"
            android:padding="16dp"
            android:text="Bắt đầu ôn tập để xem thống kê!"
            android:textSize="14sp"
            android:textColor="@color/muted"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
