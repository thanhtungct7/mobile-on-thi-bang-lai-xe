<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".KetQuaActivity">

    <include layout="@layout/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Verdict text (standalone, like prototype) -->
            <TextView
                android:id="@+id/txtResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="18dp"
                android:text="KHÔNG ĐẠT"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/result_fail_fg"
                android:letterSpacing="-0.02"
                android:lineSpacingExtra="-2dp" />

            <TextView
                android:id="@+id/txtLyDo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="16dp"
                android:text="Không trả lời đúng đủ số câu"
                android:textSize="13sp"
                android:textColor="@color/muted" />

            <!-- Score card: left = number/label, right = ring -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Left: score info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Điểm của bạn"
                            android:textSize="11sp"
                            android:textColor="@color/muted"
                            android:letterSpacing="0.06"
                            android:textAllCaps="true"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/txtScoreNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="42sp"
                                android:textStyle="bold"
                                android:textColor="@color/result_fail_fg"
                                android:letterSpacing="-0.04"
                                android:lineSpacingExtra="-4dp"
                                android:fontFamily="monospace" />

                            <TextView
                                android:id="@+id/txtScoreDenom"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:layout_marginBottom="8dp"
                                android:text="/25"
                                android:textSize="20sp"
                                android:textColor="@color/muted"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Điểm đạt là 21/25 câu."
                            android:textSize="13sp"
                            android:textColor="@color/muted" />

                    </LinearLayout>

                    <!-- Right: circular ring -->
                    <com.kma.OnThiBangLaiXe.ReadinessRingView
                        android:id="@+id/ringScore"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_marginStart="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Time stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thời gian làm"
                            android:textSize="11sp"
                            android:textColor="@color/muted"
                            android:letterSpacing="0.04"
                            android:textAllCaps="true"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/txtThoiGianLam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="--:--"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/fg"
                            android:letterSpacing="-0.03"
                            android:fontFamily="monospace" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Còn lại"
                            android:textSize="11sp"
                            android:textColor="@color/muted"
                            android:letterSpacing="0.04"
                            android:textAllCaps="true"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/txtThoiGianConLai"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="--:--"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/fg"
                            android:letterSpacing="-0.03"
                            android:fontFamily="monospace" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Filter tabs (segment control) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnAll"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/txtCountAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/fg"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng"
                            android:textSize="10sp"
                            android:textColor="@color/muted"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />

                    <LinearLayout
                        android:id="@+id/btnTrue"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/txtCountTrue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/result_pass_fg"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đúng"
                            android:textSize="10sp"
                            android:textColor="@color/muted"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />

                    <LinearLayout
                        android:id="@+id/btnFalse"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/txtCountFalse"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/result_fail_fg"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sai"
                            android:textSize="10sp"
                            android:textColor="@color/muted"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />

                    <LinearLayout
                        android:id="@+id/btnNull"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/txtCountNull"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/muted"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bỏ"
                            android:textSize="10sp"
                            android:textColor="@color/muted"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bubble grid section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bản đồ câu hỏi"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/fg" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bubble_skip_bg"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điểm liệt"
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Bubble grid fragment container -->
            <FrameLayout
                android:id="@+id/fm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
