<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Question header card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/answer_card_default"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp">

                <!-- Question number badge -->
                <LinearLayout
                    android:id="@+id/badgeGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/accent_card_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/txtSoCauHoi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Câu 1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                    <TextView
                        android:id="@+id/txtDungSai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginStart="6dp"/>

                    <ImageView
                        android:id="@+id/ivDungSai"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"/>

                </LinearLayout>

                <!-- Save icon -->
                <ImageView
                    android:id="@+id/ivSave"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/baseline_bookmark_24"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Question text -->
        <TextView
            android:id="@+id/txtNoiDungCauHoi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.35"
            android:letterSpacing="-0.01"
            android:textColor="@color/fg"/>

        <!-- Question image -->
        <ImageView
            android:id="@+id/ivCauHoi"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="10dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="@drawable/answer_card_default"
            android:src="@drawable/banner"/>

        <!-- Answer options container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="4dp">

            <!-- Option A -->
            <LinearLayout
                android:id="@+id/wrapA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/answer_card_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvLetterA"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/answer_letter_bg"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <RadioButton
                    android:id="@+id/rbA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@android:color/transparent"
                    android:background="@android:color/transparent"
                    android:paddingStart="10dp"
                    android:textColor="@color/fg"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Option B -->
            <LinearLayout
                android:id="@+id/wrapB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/answer_card_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvLetterB"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/answer_letter_bg"
                    android:gravity="center"
                    android:text="B"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <RadioButton
                    android:id="@+id/rbB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@android:color/transparent"
                    android:background="@android:color/transparent"
                    android:paddingStart="10dp"
                    android:textColor="@color/fg"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Option C -->
            <LinearLayout
                android:id="@+id/wrapC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/answer_card_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvLetterC"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/answer_letter_bg"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <RadioButton
                    android:id="@+id/rbC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@android:color/transparent"
                    android:background="@android:color/transparent"
                    android:paddingStart="10dp"
                    android:textColor="@color/fg"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Option D -->
            <LinearLayout
                android:id="@+id/wrapD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/answer_card_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvLetterD"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/answer_letter_bg"
                    android:gravity="center"
                    android:text="D"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <RadioButton
                    android:id="@+id/rbD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@android:color/transparent"
                    android:background="@android:color/transparent"
                    android:paddingStart="10dp"
                    android:textColor="@color/fg"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Explanation -->
        <TextView
            android:id="@+id/txtGiaiThichCauHoi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/explanation_card_bg"
            android:padding="14dp"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:textColor="@color/fg2"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGiaiThichBienBao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:padding="14dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
