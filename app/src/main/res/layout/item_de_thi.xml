<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@drawable/card_de_thi_new"
    android:minHeight="100dp"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp">

    <TextView
        android:id="@+id/txtLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đề thi số"
        android:textSize="10sp"
        android:textColor="@color/muted" />

    <TextView
        android:id="@+id/txt_DeThi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/fg"
        android:fontFamily="monospace"
        android:lineSpacingExtra="0dp" />

    <LinearLayout
        android:id="@+id/layoutResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivCauDung"
            android:layout_width="12dp"
            android:layout_height="12dp"
            app:srcCompat="@drawable/baseline_check_circle_12" />

        <TextView
            android:id="@+id/txtSoCauDung"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="6dp"
            android:textColor="@color/result_pass_fg" />

        <ImageView
            android:id="@+id/ivSai"
            android:layout_width="12dp"
            android:layout_height="12dp"
            app:srcCompat="@drawable/baseline_cancel_12" />

        <TextView
            android:id="@+id/txtSoCauSai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            android:textColor="@color/result_fail_fg" />
    </LinearLayout>
</LinearLayout>
